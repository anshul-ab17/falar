{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Falar",
  "version": "0.1.0",
  "identifier": "com.atuly.falar",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Falar",
        "width": 900,
        "height": 700,
        "minWidth": 700,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "dialog": {},
    "fs": {
      "scope": ["$APPDATA/**", "$DOWNLOAD/**", "$DOCUMENT/**"]
    },
    "clipboard-manager": {}
  }
}
